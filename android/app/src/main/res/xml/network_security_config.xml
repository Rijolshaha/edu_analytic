<?xml version="1.0" encoding="utf-8"?>
<!--
    EduAnalytics — Network Security Config
    ==========================================
    Production:  https://eduanalytics.pythonanywhere.com  → HTTPS (default, xavfsiz)
    Development: http://localhost:8000  yoki  http://10.0.2.2:8000  → HTTP (lokal test)

    10.0.2.2 — Android emulator ichidan host mashinasiga kirish manzili (localhost o'rniga)
    192.168.x.x — real qurilmada lokal WiFi orqali server bilan bog'lanish
-->
<network-security-config>

    <!-- ✅ Production: HTTPS — hech qanday qo'shimcha ruxsat kerak emas -->
    <domain-config cleartextTrafficPermitted="false">
        <domain includeSubdomains="true">eduanalytics.pythonanywhere.com</domain>
    </domain-config>

    <!-- 🛠️ Development: localhost va emulator IP → HTTP ruxsat berilgan -->
    <domain-config cleartextTrafficPermitted="true">
        <!-- Android emulator ichidan host machine ga kirish -->
        <domain includeSubdomains="false">10.0.2.2</domain>
        <!-- Lokal IP manzilar (real qurilmadan WiFi orqali) -->
        <domain includeSubdomains="false">192.168.1.1</domain>
        <domain includeSubdomains="false">192.168.0.1</domain>
        <!-- Localhost (ba'zi qurilmalarda ishlashi mumkin) -->
        <domain includeSubdomains="false">localhost</domain>
        <domain includeSubdomains="false">127.0.0.1</domain>
    </domain-config>

    <!-- ✅ Qolgan barcha domenlar uchun: faqat HTTPS -->
    <base-config cleartextTrafficPermitted="false">
        <trust-anchors>
            <certificates src="system"/>
        </trust-anchors>
    </base-config>

</network-security-config>
